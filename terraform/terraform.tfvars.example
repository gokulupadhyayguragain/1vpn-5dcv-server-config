project_name         = "dcv-improvised"
aws_region           = "us-east-1"
availability_zone    = "us-east-1a"
vpc_cidr             = "10.20.0.0/16"
public_subnet_cidr   = "10.20.1.0/24"
private_subnet_cidr  = "10.20.2.0/24"
vpn_private_ip       = "10.20.1.10"
dcv_private_ips      = ["10.20.2.10", "10.20.2.11"]
vpn_client_cidr      = "10.8.0.0/24"
dcv_self_service_port = 8444
allowed_admin_cidr   = "203.0.113.10/32"
create_vpn_eip       = true
vpn_eip_allocation_id = ""
vpn_dcv_control_instance_profile_name = ""
vpn_instance_type    = "t2.micro"
dcv_instance_type    = "t3.large"
dcv_instance_count   = 2
dcv_use_spot         = true
dcv_spot_max_price   = ""
vpn_root_volume_size_gb = 8
dcv_root_volume_size_gb = 30
ssh_public_key_path  = "~/.ssh/id_ed25519.pub"
ssh_key_name         = "dcv-improvised-key"
create_s3_bucket     = true
s3_bucket_name       = ""
# KEEP USER COUNT AND DCV INSTANCE COUNT MATCHED FOR DEDICATED USER-TO-HOST ASSIGNMENTS.
vpn_users            = ["user1", "user2"]
