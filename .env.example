# CENTRAL CONFIG BLOCK
# CENTRALIZES ALL REQUIRED INPUTS FOR TERRAFORM AND ANSIBLE.
AWS_ACCESS_KEY_ID=VALUE
AWS_SECRET_ACCESS_KEY=VALUE
AWS_REGION=ap-south-1
AWS_SESSION_TOKEN=

# PROJECT SIZING BLOCK
# CONTROLS INSTANCE COUNT, SIZE, STORAGE, AND NETWORK RANGES.
PROJECT_NAME=dcv-improvised
AWS_AVAILABILITY_ZONE=ap-south-1a
VPC_CIDR=10.20.0.0/16
PUBLIC_SUBNET_CIDR=10.20.1.0/24
PRIVATE_SUBNET_CIDR=10.20.2.0/24
VPN_CLIENT_CIDR=10.8.0.0/24
DCV_VPN_ACTIVE_SECONDS=180
DCV_DISCONNECT_GRACE_SECONDS=600
DCV_IDLE_TIMEOUT_MINUTES=10
DCV_IDLE_TIMEOUT_WARNING_SECONDS=120
DCV_STOP_AFTER_IDLE_DISCONNECT_SECONDS=60
ALLOWED_ADMIN_CIDR=0.0.0.0/0
VPN_PRIVATE_IP=10.20.1.10
DCV_PRIVATE_IPS_CSV=10.20.2.10,10.20.2.11,10.20.2.12,10.20.2.13,10.20.2.14
# KEEP STATIC PRIVATE IPS HERE SO YOUR CLIENT-FACING DCV ADDRESSES DO NOT CHANGE AFTER A FUTURE DESTROY/CREATE.

# COMPUTE BLOCK
# DEFINES VPN/NAT AND DCV INSTANCE SHAPES AND STORAGE SIZE.
# t3.small = 2 vCPU, 2 GB RAM || t2.micro = 1 vCPU, 1 GB RAM (FREE TIER ELIGIBLE)
# t3.medium = 2 vCPU, 4 GB RAM || t2.small = 1 vCPU, 2 GB RAM
# t3.large = 2 vCPU, 8 GB RAM || t2.medium = 2 vCPU, 4 GB RAM
VPN_INSTANCE_TYPE=t2.micro    # CHANGED TO t2.micro FOR COST OPTIMIZATION
CREATE_VPN_EIP=true           # CREATE_VPN_EIP=true = STATIC PUBLIC IP FOR EC2 STOP/START. FOR THE SAME PUBLIC IP ACROSS DESTROY/CREATE, SET CREATE_VPN_EIP=false AND PROVIDE VPN_EIP_ALLOCATION_ID.
DCV_INSTANCE_TYPE=t3.medium
DCV_INSTANCE_COUNT=5
DCV_USE_SPOT=true           # true = launch DCV as Spot for cost savings, false = launch On-Demand
DCV_SPOT_MAX_PRICE=         # OPTIONAL: cap Spot hourly price, leave empty for market price
DCV_SWAP_SIZE_GB=4
DCV_CONFIG_SERIAL=5           # 5 = PARALLEL CONFIGURATION, 1 = SERIAL CONFIGURATION
DCV_SELF_SERVICE_PORT=8444
VPN_ROOT_VOLUME_SIZE_GB=8
DCV_ROOT_VOLUME_SIZE_GB=50
VPN_EIP_ALLOCATION_ID=        # EXAMPLE: VPN_EIP_ALLOCATION_ID=eipalloc-0123456789abcdef0
VPN_DCV_CONTROL_INSTANCE_PROFILE_NAME=
# VPN_DCV_CONTROL_INSTANCE_PROFILE_NAME=dcv-improvised-vpn-dcv-control-profile

# SSH BLOCK
# DEFINES KEYPAIR MATERIAL TO ACCESS INSTANCES.
# DEFAULT USING SAME KEYS AS GITHUB SSH, BUT YOU CAN CHANGE TO ANY KEYPAIR YOU WANT.
SSH_PUBLIC_KEY_PATH=~/.ssh/id_ed25519.pub
SSH_PRIVATE_KEY_PATH=~/.ssh/id_ed25519
SSH_KEY_NAME=dcv-improvised-key

# USER ACCESS BLOCK
# DEFINES THE 1:1 USER-TO-DCV-HOST MAPPING AND EACH USER PASSWORD KEY.
VPN_USERS_CSV=user1,user2,user3,user4,user5
DCV_SUDO_USER1=true
DCV_SUDO_USER2=true
DCV_SUDO_USER3=true
DCV_SUDO_USER4=true
DCV_SUDO_USER5=true
DCV_PASSWORD_USER1=qwerty@12345
DCV_PASSWORD_USER2=abcdef@12345
DCV_PASSWORD_USER3=123456@12345
DCV_PASSWORD_USER4=asdfgh@12345
DCV_PASSWORD_USER5=zxcvbn@12345

# S3 ARTIFACT BLOCK
# DEFINES WHERE VPN CLIENT FILES AND CONNECTION INFO ARE STORED.
CREATE_S3_BUCKET=false     # true IF FIRST TIME DEPLOYING TO CREATE THE BUCKET, false IF BUCKET ALREADY EXISTS
S3_BUCKET_NAME=5dcv-1-vpn-server-tf-state-file-bucket 

# DCV INSTALLATION BLOCK
# AMI_ID SHOULD POINT TO A GOLDEN AMI THAT ALREADY HAS HEAVY TOOLS (CHROME, DOCKER, FLUTTER, VS CODE) FOR FAST SPOT REPLACEMENT.
AMI_ID=
NICE_DCV_DOWNLOAD_URL=https://d1uj6qtbmh3dt5.cloudfront.net/2025.0/Servers/nice-dcv-2025.0-20103-ubuntu2404-x86_64.tgz
DCV_BOOTSTRAP_TIMEOUT_SECONDS=5400
DCV_BOOTSTRAP_POLL_INTERVAL_SECONDS=20
TF_STATE_KEY=terraform/dcv-improvised.tfstate
