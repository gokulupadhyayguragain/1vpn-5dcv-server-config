#!/usr/bin/env python3
import base64
import crypt
import hashlib
import hmac
import html
import json
import ssl
import subprocess
import sys
from http import HTTPStatus
from http.cookies import SimpleCookie
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
from urllib.parse import parse_qs, urlparse

CONFIG_PATH = sys.argv[1] if len(sys.argv) > 1 else "/etc/dcv-self-service/config.json"
with open(CONFIG_PATH, encoding="utf-8") as config_file:
    CONFIG = json.load(config_file)

REALM = f"{CONFIG['project_name']} DCV SELF-SERVICE"
JSON_HEADERS = {
    "Cache-Control": "no-store",
    "Content-Type": "application/json; charset=utf-8",
}
HTML_HEADERS = {
    "Cache-Control": "no-store",
    "Content-Type": "text/html; charset=utf-8",
}


# AUTHENTICATION BLOCK
# ENFORCES BASIC AUTH WITH THE SAME DCV USERNAME AND PASSWORD SO USERS ONLY NEED THEIR VPN PROFILE PLUS THEIR NORMAL DCV CREDENTIALS.
def parse_basic_auth(header_value):
    if not header_value or not header_value.startswith("Basic "):
        return "", ""

    try:
        decoded_value = base64.b64decode(header_value.split(" ", 1)[1]).decode("utf-8")
    except Exception:
        return "", ""

    if ":" not in decoded_value:
        return "", ""

    username, password = decoded_value.split(":", 1)
    return username, password


def load_user_record(username):
    return CONFIG["users"].get(username)


def verify_password(username, password):
    user_record = load_user_record(username)
    if not user_record:
        return False

    password_hash = user_record["password_hash"]
    return hmac.compare_digest(crypt.crypt(password, password_hash), password_hash)


def build_csrf_token(username):
    secret_material = f"{CONFIG['csrf_secret']}:{username}:{CONFIG['users'][username]['password_hash']}"
    return hmac.new(
        CONFIG["csrf_secret"].encode("utf-8"),
        secret_material.encode("utf-8"),
        hashlib.sha256,
    ).hexdigest()


def parse_helper_output(output_text):
    parsed_output = {}
    for raw_line in output_text.splitlines():
        if "=" in raw_line:
            key, value = raw_line.split("=", 1)
            parsed_output[key] = value
    return parsed_output


def run_helper(action, username):
    completed_process = subprocess.run(
        [CONFIG["helper_path"], "--admin", action, username],
        capture_output=True,
        text=True,
        check=False,
    )
    if completed_process.returncode != 0:
        error_text = completed_process.stderr.strip() or completed_process.stdout.strip() or "UNKNOWN HELPER ERROR"
        raise RuntimeError(error_text)

    helper_result = parse_helper_output(completed_process.stdout)
    helper_result["ACTION"] = action
    return helper_result


class DcvSelfServiceHandler(BaseHTTPRequestHandler):
    def log_message(self, format_string, *args):
        return

    def request_authentication(self):
        self.send_response(HTTPStatus.UNAUTHORIZED)
        self.send_header("WWW-Authenticate", f'Basic realm="{REALM}"')
        self.send_header("Cache-Control", "no-store")
        self.end_headers()

    def authenticate(self):
        username, password = parse_basic_auth(self.headers.get("Authorization", ""))
        if not username or not verify_password(username, password):
            self.request_authentication()
            return None
        return username

    def send_json_response(self, status_code, payload):
        payload_bytes = json.dumps(payload, indent=2, sort_keys=True).encode("utf-8")
        self.send_response(status_code)
        for header_name, header_value in JSON_HEADERS.items():
            self.send_header(header_name, header_value)
        self.send_header("Content-Length", str(len(payload_bytes)))
        self.end_headers()
        self.wfile.write(payload_bytes)

    def send_html_response(self, status_code, html_body, csrf_token=""):
        body_bytes = html_body.encode("utf-8")
        self.send_response(status_code)
        for header_name, header_value in HTML_HEADERS.items():
            self.send_header(header_name, header_value)
        if csrf_token:
            self.send_header(
                "Set-Cookie",
                f"dcv_self_service_csrf={csrf_token}; HttpOnly; SameSite=Strict; Secure; Path=/",
            )
        self.send_header("Content-Length", str(len(body_bytes)))
        self.end_headers()
        self.wfile.write(body_bytes)

    def send_error_page(self, username, error_text, status_code=HTTPStatus.BAD_GATEWAY):
        page_html = self.render_dashboard(username, {}, {"MESSAGE": error_text})
        self.send_html_response(status_code, page_html, build_csrf_token(username))

    def read_form_body(self):
        content_length = int(self.headers.get("Content-Length", "0") or "0")
        raw_body = self.rfile.read(content_length).decode("utf-8")
        return parse_qs(raw_body)

    def valid_html_csrf(self, username, form_data):
        cookie = SimpleCookie(self.headers.get("Cookie", ""))
        cookie_token = cookie.get("dcv_self_service_csrf")
        form_token = form_data.get("csrf_token", [""])[0]
        expected_token = build_csrf_token(username)
        return (
            cookie_token is not None
            and hmac.compare_digest(cookie_token.value, expected_token)
            and hmac.compare_digest(form_token, expected_token)
        )

    # RESPONSE RENDER BLOCK
    # PROVIDES BOTH A SIMPLE BROWSER PAGE AND CURL-FRIENDLY JSON ENDPOINTS SO USERS CAN SELF-SERVICE POWER ACTIONS AFTER CONNECTING TO THE VPN.
    def render_dashboard(self, username, status_result, message_result):
        safe_username = html.escape(username)
        state_value = html.escape(status_result.get("STATE", "UNKNOWN"))
        instance_id = html.escape(status_result.get("INSTANCE_ID", "UNKNOWN"))
        private_ip = html.escape(status_result.get("DCV_PRIVATE_IP", "UNKNOWN"))
        web_url = html.escape(status_result.get("DCV_WEB_URL", "UNKNOWN"))
        ready_state = html.escape(message_result.get("READY", ""))
        message_text = html.escape(message_result.get("MESSAGE", ""))
        csrf_token = build_csrf_token(username)

        message_block = ""
        if ready_state or message_text:
            message_block = f"""
            <section class="message">
              <p><strong>READY:</strong> {ready_state or "N/A"}</p>
              <p><strong>MESSAGE:</strong> {message_text or "NONE"}</p>
            </section>
            """

        return f"""<!DOCTYPE html>
