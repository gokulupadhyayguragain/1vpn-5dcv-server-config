    def do_GET(self):
        parsed_path = urlparse(self.path)
        if parsed_path.path == "/healthz":
            self.send_json_response(HTTPStatus.OK, {"status": "ok"})
            return

        username = self.authenticate()
        if username is None:
            return

        try:
            status_result = run_helper("status", username)
        except RuntimeError as error:
            if parsed_path.path == "/status":
                self.send_json_response(HTTPStatus.BAD_GATEWAY, {"error": str(error), "user": username})
                return
            self.send_error_page(username, str(error))
            return

        if parsed_path.path == "/status":
            self.send_json_response(HTTPStatus.OK, {"user": username, "result": status_result})
            return

        page_html = self.render_dashboard(username, status_result, {})
        self.send_html_response(HTTPStatus.OK, page_html, build_csrf_token(username))

    def do_POST(self):
        parsed_path = urlparse(self.path)
        username = self.authenticate()
        if username is None:
            return

        if parsed_path.path in {"/start", "/stop"}:
            form_data = self.read_form_body()
            if not self.valid_html_csrf(username, form_data):
                self.send_error_page(username, "INVALID OR MISSING CSRF TOKEN.", HTTPStatus.FORBIDDEN)
                return
            action = parsed_path.path.lstrip("/")
            try:
                action_result = run_helper(action, username)
                status_result = run_helper("status", username)
            except RuntimeError as error:
                self.send_error_page(username, str(error))
                return
            page_html = self.render_dashboard(username, status_result, action_result)
            self.send_html_response(HTTPStatus.OK, page_html, build_csrf_token(username))
            return

        if parsed_path.path in {"/api/start", "/api/stop"}:
            action = parsed_path.path.rsplit("/", 1)[-1]
            try:
                action_result = run_helper(action, username)
            except RuntimeError as error:
                self.send_json_response(HTTPStatus.BAD_GATEWAY, {"error": str(error), "user": username})
                return
            self.send_json_response(HTTPStatus.OK, {"user": username, "result": action_result})
            return

        self.send_json_response(HTTPStatus.NOT_FOUND, {"error": "NOT FOUND"})


def main():
    ssl_context = ssl.SSLContext(ssl.PROTOCOL_TLS_SERVER)
    ssl_context.load_cert_chain(CONFIG["tls_cert_path"], CONFIG["tls_key_path"])

    http_server = ThreadingHTTPServer((CONFIG["bind_host"], int(CONFIG["port"])), DcvSelfServiceHandler)
    http_server.socket = ssl_context.wrap_socket(http_server.socket, server_side=True)
    http_server.serve_forever()


if __name__ == "__main__":
    main()
